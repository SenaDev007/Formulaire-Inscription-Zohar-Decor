# ===== Database =====
# DEV (local SQLite — for quick testing):
# DATABASE_URL="file:./dev.db"
#
# PRODUCTION (Vercel + Vercel Postgres / Supabase / Neon):
# Example Vercel Postgres: postgresql://user:pass@host:5432/db?pgbouncer=true
# Example Supabase:        postgresql://postgres.xxxx:pass@xxxx.supabase.co:5432/postgres
# Example Neon:            postgresql://user:pass@ep-xxxx.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/zohar_decor?schema=public"

# ===== App =====
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_WHATSAPP_NUMBER="22900000000"  # WhatsApp Business Zohar Décor (international format, no +)

# ===== Admin bootstrap =====
# Used by /api/seed to create the first admin user
ADMIN_BOOTSTRAP_EMAIL="admin@zohardecor.com"
ADMIN_BOOTSTRAP_PASSWORD="change-me-to-a-strong-password"

# ===== JWT =====
# Generate with: openssl rand -base64 64
JWT_SECRET="generate-a-long-random-string-at-least-64-chars"
JWT_EXPIRES_IN="7d"

# ===== Resend (Email) =====
# Get key: https://resend.com/api-keys
# Verify your domain (academiahelm.com or yours) in Resend dashboard
RESEND_API_KEY="re_xxxxxxxxxx"
RESEND_TO_EMAIL="auroretheodoraa@gmail.com"
EMAIL_FROM_NOREPLY="noreply@academiahelm.com"
EMAIL_FROM_NAME="Zohar Décor"

# ===== FeeXPay (Payment) =====
# Docs: https://docs.feexpay.me
# Get credentials: https://feexpay.me dashboard → API / Integration
# FEEXPAY_SHOP_ID = your merchant shop ID
# FEEXPAY_API_TOKEN = your API token (sent in request body, NOT as Bearer)
# Leave both empty to run in DEMO MODE (payments auto-confirm for testing)
FEEXPAY_BASE_URL="https://api.feexpay.me"
FEEXPAY_SHOP_ID=""
FEEXPAY_API_TOKEN=""
FEEXPAY_SANDBOX="true"  # set to "false" in production

# ===== Contact / Brand =====
CONTACT_PHONE="+22900000000"
CONTACT_EMAIL="auroretheodoraa@gmail.com"

# ===== Vercel-specific (optional) =====
# Vercel automatically sets these, but you can override:
# NEXT_PUBLIC_VERCEL_URL is set automatically by Vercel
# Use it to build absolute URLs in production
