# Copy this file to .env and fill in real values

# Database (SQLite for dev — switch to postgresql/mysql in production)
DATABASE_URL="file:./dev.db"

# App
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_WHATSAPP_NUMBER="22900000000"

# Admin bootstrap (used by `bun run db:seed` to create the first admin)
ADMIN_BOOTSTRAP_EMAIL="admin@zohardecor.com"
ADMIN_BOOTSTRAP_PASSWORD="change-me"

# JWT
JWT_SECRET="generate-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Resend (Email) — https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxx"
EMAIL_FROM_NOREPLY="noreply@academiahelm.com"
EMAIL_FROM_NAME="Zohar Décor"

# Flexpay — https://flexpay.cd
FLEXPAY_BASE_URL="https://payment.flexpay.cd/api/v1"
FLEXPAY_MERCHANT_TOKEN="your-merchant-token"
FLEXPAY_WEBHOOK_SECRET=""
FLEXPAY_SANDBOX="false"

# Contact / Brand
CONTACT_PHONE="+22900000000"
CONTACT_EMAIL="contact@zohardecor.com"
