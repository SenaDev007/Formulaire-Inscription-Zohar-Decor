// Zohar Décor - Formation Résine Époxy
// Prisma schema — PostgreSQL via Prisma Accelerate

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Participant {
  id                  String     @id @default(cuid())
  registrationId      String     @unique
  nomComplet          String
  prenoms             String
  sexe                String
  dateNaissance       String
  telWhatsApp         String
  telSecondaire       String?
  email               String
  ville               String
  profession          String
  niveauEtudes        String
  sourceConnaissance  String
  acceptConditions    Boolean    @default(false)
  status              String     @default("PENDING")
  paymentType         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  payments            Payment[]

  @@index([email])
  @@index([telWhatsApp])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id                  String     @id @default(cuid())
  participantId       String
  participant         Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  amount              Int
  type                String
  provider            String
  providerPhone       String?
  feexpayReference    String?    @unique
  feexpayOrderNumber  String?
  feexpayTransaction  String?
  status              String     @default("PENDING")
  paymentUrl          String?
  manuallyValidated   Boolean    @default(false)
  validatedById       String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([participantId])
  @@index([status])
  @@index([feexpayReference])
}

model AdminUser {
  id                  String     @id @default(cuid())
  email               String     @unique
  name                String
  passwordHash        String
  role                String     @default("ADMIN")
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Setting {
  id                  String     @id @default(cuid())
  key                 String     @unique
  value               String
  updatedAt           DateTime   @updatedAt
}
